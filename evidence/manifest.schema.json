{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.local/schemas/manifest.schema.json",
  "title": "Evidence Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "day",
    "git_sha",
    "created_at",
    "commands",
    "artifact_paths"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "pattern": "^[a-z0-9-]{1,40}$" },
    "day": {
      "type": "string",
      "enum": ["1A", "1B", "2A", "2B", "3", "4", "5"]
    },
    "git_sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "created_at": { "type": "string", "format": "date-time" },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cmd", "exit_code"],
        "properties": {
          "cmd": { "type": "string", "minLength": 1 },
          "exit_code": { "type": "integer" },
          "stdout_path": { "type": "string" },
          "stderr_path": { "type": "string" },
          "duration_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "artifact_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "bytes"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "claude_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_path", "transcript_path"],
      "properties": {
        "report_path": { "type": "string" },
        "transcript_path": { "type": "string" },
        "verdict": { "type": "string", "enum": ["PASS", "WARN", "BLOCK"] }
      }
    },
    "notes": { "type": "string" }
  }
}
