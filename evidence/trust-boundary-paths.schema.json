{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://relay.local/schemas/trust-boundary-paths.schema.json",
  "title": "Trust-boundary paths",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "globs"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "globs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "string" }
  }
}
