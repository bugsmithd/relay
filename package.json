{
  "name": "relay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:canonical": "next dev -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "seed": "node --conditions=react-server scripts/seed.ts",
    "seed:cleanup": "node --conditions=react-server scripts/seed-cleanup.mjs",
    "test:unit": "node --test tests/auth/magic-link-redirect-allowlist.spec.ts tests/rls/migration-rls-enabled.spec.ts",
    "test:db": "node --conditions=react-server --test tests/rls/workspace-select-membership.spec.ts tests/rls/workspace-write-denial.spec.ts tests/auth/workspace-guard.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:magic": "playwright test --config=playwright.magic.config.ts"
  },
  "dependencies": {
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.105.4",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "22.18.10",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "ajv": "8.17.1",
    "ajv-cli": "5.0.0",
    "ajv-formats": "3.0.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "@tailwindcss/oxide"]
  }
}
